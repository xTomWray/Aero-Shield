# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.
# See docs/INTEGRATION.md §8 for full variable descriptions.

# Base URL of your backend API server (no trailing slash).
# The frontend appends: GET /snapshot?scenario=<id>  and  POST /scenario/<id>
VITE_API_BASE_URL=http://localhost:3000

# Set to "true" to always use the built-in mock provider, even if VITE_API_BASE_URL is set.
# Useful when working on UI-only changes without a running backend.
VITE_FORCE_MOCK=false

# Which scenario to load on first render.
# One of: baseline | storm-front | intrusion | recovery
VITE_INITIAL_SCENARIO=baseline

# Frontend log verbosity.
# One of: debug | info | warn | error
VITE_LOG_LEVEL=warn
